generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(uuid())
  name      String
  goal      String
  owner     String   @default("boss")
  status    String   @default("Active")
  createdAt DateTime @default(now()) @map("created_at")
  tasks      Task[]
  blueprints Blueprint[]

  @@map("projects")
}

model Task {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  title     String
  assignee  String   @default("unassigned")
  type      String   @default("Task")
  dependsOn String   @default("[]") @map("depends_on")
  status    String   @default("Backlog")
  note      String   @default("")
  artifacts String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  timeoutAt   DateTime? @map("timeout_at")
  escalatedAt DateTime? @map("escalated_at")

  project   Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([assignee])
  @@index([timeoutAt])
  @@map("tasks")
}

model EventLog {
  id        String   @id @default(uuid())
  type      String
  payload   String
  actorId   String   @map("actor_id")
  actorRole String   @map("actor_role")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([createdAt])
  @@map("event_logs")
}

model Template {
  id             String @id @default(uuid())
  name           String
  tags           String @default("[]")
  defaultTimeout Int    @default(60) @map("default_timeout")

  @@map("templates")
}

model Worker {
  id          String  @id @default(uuid())
  name        String
  tags        String  @default("[]")
  status      String  @default("idle")
  callbackUrl String? @map("callback_url")

  @@map("workers")
}

model Blueprint {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  title       String
  requirement String   @default("")
  status      String   @default("Draft")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project     Project         @relation(fields: [projectId], references: [id])
  nodes       BlueprintNode[]

  @@index([projectId])
  @@index([status])
  @@map("blueprints")
}

model BlueprintNode {
  id          String   @id @default(uuid())
  blueprintId String   @map("blueprint_id")
  parentId    String?  @map("parent_id")
  level       String   @default("task")
  title       String
  description String   @default("")
  sortOrder   Int      @default(0) @map("sort_order")
  taskType    String   @default("Task") @map("task_type")
  assignee    String?
  timeoutMin  Int      @default(60) @map("timeout_min")
  dependsOn   String   @default("[]") @map("depends_on")

  blueprint   Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  @@index([blueprintId])
  @@map("blueprint_nodes")
}
